{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL", "ANTHROPIC_API_KEY", "GITHUB_TOKEN"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": { "cache": false, "persistent": true },
    "check": {},
    "db:generate": { "cache": false },
    "db:migrate": { "cache": false }
  }
}
